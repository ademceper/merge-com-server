{
  "realm": "notification",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      { "name": "owner", "description": "Full access owner role" },
      { "name": "admin", "description": "Admin role" },
      { "name": "author", "description": "Author role" },
      { "name": "viewer", "description": "Read-only viewer role" }
    ]
  },
  "clients": [
    {
      "clientId": "notification-api",
      "name": "Notification API",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": ["http://localhost:3010/*"],
      "webOrigins": ["+"],
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email"],
      "protocolMappers": [
        {
          "name": "organizationId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "organizationId",
            "claim.name": "organizationId",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "dev",
      "email": "dev@localhost.com",
      "firstName": "Dev",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "attributes": {
        "organizationId": ["dev-org-001"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "dev",
          "temporary": false
        }
      ],
      "realmRoles": ["owner"]
    }
  ]
}
