{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "sourceMap": true,
    "strictNullChecks": true,
    "target": "es6",
    "declaration": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "lib": ["es2021"],
    "baseUrl": "./src"
  },
  "exclude": [
    "node_modules",
    "e2e",
    "migrations",
    "src/**/*.spec.ts",
    "src/**/*.e2e.ts",
    "src/**/*.e2e-ee.ts",
    "src/**/*.test.ts",
    "src/**/*.test-d.ts",
    "src/libs/framework/servers/h3.ts",
    "src/libs/framework/servers/next.ts",
    "src/libs/framework/servers/nuxt.ts",
    "src/libs/framework/servers/sveltekit.ts",
    "src/libs/internal-sdk/react-query",
    "src/**/e2e/**",
    "src/libs/providers/utils/test",
    "scripts"
  ]
}
